---
const {
  title = "FixBiz — Redressement, trésorerie et accompagnement dirigeant",
  description = "FixBiz accompagne les dirigeants de TPE et PME : redressement d’entreprise, trésorerie, rentabilité, structuration, pilotage opérationnel et cession.",
  canonical = "https://fixbiz.fr/"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="robots"
    content="index, follow"
  />

  <meta
    name="theme-color"
    content="#2e7fb1"
  />

  <meta
    property="og:type"
    content="website"
  />

  <meta
    property="og:locale"
    content="fr_FR"
  />

  <meta
    property="og:title"
    content={title}
  />

  <meta
    property="og:description"
    content={description}
  />

  <meta
    property="og:url"
    content={canonical}
  />

  <meta
    property="og:site_name"
    content="FixBiz"
  />

  <meta
    property="og:image"
    content="https://fixbiz.fr/og-fixbiz.jpg"
  />

  <meta
    name="twitter:card"
    content="summary_large_image"
  />

  <meta
    name="twitter:title"
    content={title}
  />

  <meta
    name="twitter:description"
    content={description}
  />

  <meta
    name="twitter:image"
    content="https://fixbiz.fr/og-fixbiz.jpg"
  />

  <link
    rel="canonical"
    href={canonical}
  />

  <!-- Favicon -->

  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href="/favicon.png"
  />

  <link
    rel="apple-touch-icon"
    href="/apple-touch-icon.png"
  />

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <style is:global>

    :root {
      --blue: #2e7fb1;
      --blue-dark: #1a5f8a;
      --blue-soft: #eef7fc;
      --ink: #163047;
      --muted: #607486;
      --line: #dce9f2;
      --bg: #f7fbfe;
      --white: #ffffff;
      --green: #13855b;
      --radius: 18px;

      --shadow:
        0 18px 50px rgba(22, 48, 71, .10);

      --shadow-soft:
        0 10px 28px rgba(22, 48, 71, .07);

      --max: 1160px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;

      font-family:
        'Plus Jakarta Sans',
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        sans-serif;

      color: var(--ink);

      background: var(--white);

      line-height: 1.65;

      -webkit-font-smoothing: antialiased;

      overflow-x: hidden;
    }

    img {
      max-width: 100%;

      display: block;
    }

    a {
      color: inherit;

      text-decoration: none;
    }

    button,
    input,
    textarea {
      font: inherit;
    }

    .wrap {
      max-width: var(--max);

      margin: 0 auto;

      padding: 0 48px;

      width: 100%;
    }

    .section {
      padding: 88px 0;
    }

    .section--soft {
      background: var(--bg);
    }

    .eyebrow {
      display: inline-flex;

      align-items: center;

      gap: .4rem;

      width: fit-content;

      padding: .42rem .85rem;

      border: 1px solid var(--line);

      border-radius: 999px;

      background: var(--blue-soft);

      color: var(--blue-dark);

      font-size: .78rem;

      font-weight: 800;

      letter-spacing: .01em;
    }

    .section-head {
      max-width: 740px;

      margin-bottom: 38px;
    }

    .section-head--center {
      margin-left: auto;

      margin-right: auto;

      text-align: center;
    }

    .section-title {
      margin: .8rem 0 .7rem;

      font-size: clamp(2rem, 4vw, 3.15rem);

      line-height: 1.12;

      letter-spacing: -.04em;

      color: var(--ink);

      font-weight: 800;
    }

    .section-title--small {
      font-size: clamp(1.7rem, 3vw, 2.35rem);
    }

    .section-sub {
      margin: 0;

      color: var(--muted);

      font-size: 1rem;

      max-width: 680px;
    }

    .section-head--center .section-sub {
      margin-left: auto;

      margin-right: auto;
    }

    .btn {
      display: inline-flex;

      align-items: center;

      justify-content: center;

      gap: .45rem;

      padding: .82rem 1.25rem;

      border-radius: 12px;

      font-weight: 800;

      font-size: .92rem;

      border: 1px solid transparent;

      cursor: pointer;

      transition:
        transform .18s ease,
        box-shadow .18s ease,
        background .18s ease,
        color .18s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn--primary {
      background: var(--blue);

      color: #fff;

      box-shadow:
        0 10px 24px rgba(46,127,177,.24);
    }

    .btn--primary:hover {
      background: var(--blue-dark);
    }

    .btn--ghost {
      background: #fff;

      color: var(--blue-dark);

      border-color: var(--line);
    }

    .btn--ghost:hover {
      border-color: var(--blue);

      box-shadow: var(--shadow-soft);
    }

    .card {
      background: var(--white);

      border: 1px solid var(--line);

      border-radius: var(--radius);

      box-shadow: var(--shadow-soft);
    }

    .fade {
      opacity: 0;

      transform: translateY(16px);

      transition:
        opacity .6s ease,
        transform .6s ease;
    }

    .fade.in {
      opacity: 1;

      transform: translateY(0);
    }

    @media (max-width: 900px) {

      .wrap {
        padding: 0 22px;
      }

      .section {
        padding: 68px 0;
      }

    }

  </style>

  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "FixBiz",
      "url": "https://fixbiz.fr",
      "logo": "https://fixbiz.fr/logo.png",
      "image": "https://fixbiz.fr/og-fixbiz.jpg",
      "description": "FixBiz accompagne les dirigeants de TPE et PME dans les périodes de tension : redressement d’entreprise, trésorerie, restructuration, organisation, rentabilité, cession et accompagnement opérationnel.",
      "areaServed": [
        "France",
        "Europe"
      ],
      "serviceType": [
        "Redressement d’entreprise",
        "Accompagnement dirigeant",
        "Pilotage opérationnel",
        "Amélioration de rentabilité",
        "Structuration d’entreprise",
        "Préparation à la cession"
      ],
      "email": "contact@fixbiz.fr",
      "telephone": "+33769244959",
      "founder": {
        "@type": "Person",
        "name": "Jean-Philippe Schneider"
      }
    })}
  </script>

</head>

<body>

  <slot />

</body>

</html>