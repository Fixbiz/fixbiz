---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Whatsapp from '../components/Whatsapp.astro';

const packs = [
  {
    icon: '🔧',
    id: 'resilience',
    title: 'Pack Résilience',
    subtitle: 'Difficulté • Urgences • Dettes • Trésorerie • Redressement',
    intro:
      "Quand l’activité se dégrade, que les dettes s’accumulent et que la trésorerie se tend, il faut réagir vite.",

    actions: [
      'Diagnostic rapide et clair de la situation',
      'Identification des urgences à traiter',
      'Négociation avec les créanciers',
      'Construction d’un plan de redressement',
      'Actions immédiates de stabilisation',
      'Accompagnement rapproché'
    ],

    objectif:
      "Stabiliser l’entreprise, réduire la pression financière et recréer de la marge de manœuvre.",

    conseil:
      "Plus l’intervention est précoce, plus il est possible d’éviter le pire.",

    pricing:
      "Selon la situation, la rémunération peut être structurée sous forme d’honoraires fixes, de part variable liée aux résultats obtenus ou, dans certains cas, de participation au capital de l’entreprise."
  },

  {
    icon: '📈',
    id: 'performance',
    title: 'Pack Performance',
    subtitle: 'Structuration • Organisation • Efficacité • Rentabilité',
    intro:
      "Pour les entreprises qui fonctionnent mais manquent de structure, de méthode ou de rentabilité.",

    actions: [
      'Analyse complète de l’existant',
      'Optimisation des marges et priorités',
      'Process simples et efficaces',
      'Reporting utile au dirigeant',
      'Suivi des objectifs',
      'Actions concrètes de rentabilité'
    ],

    objectif:
      "Faire mieux avec les mêmes moyens et limiter le chaos opérationnel.",

    conseil:
      "Idéal quand tout fonctionne “à peu près” mais que le dirigeant sent clairement qu’il est possible de faire mieux.",

    pricing:
      "Accompagnement mensuel avec possibilité de part variable liée à l’amélioration de la rentabilité, de la performance ou des résultats obtenus."
  },

  {
    icon: '🤝',
    id: 'soutien',
    title: 'Pack Soutien',
    subtitle: 'Accompagnement • Décisions • Charge mentale • Régularité',
    intro:
      "Le dirigeant est souvent seul face aux décisions, aux priorités et à la pression quotidienne.",

    actions: [
      'Suivi administratif régulier',
      'Point mensuel dirigeant',
      'Aide à la décision',
      'Conseils terrain',
      'Interlocuteur unique'
    ],

    objectif:
      "Réduire la charge mentale et piloter l’entreprise avec davantage de clarté.",

    conseil:
      "Le pack “ne plus être seul dans sa tête”.",

    pricing:
      "Abonnement mensuel ajusté selon le niveau de suivi, la fréquence des échanges et les besoins du dirigeant."
  },

  {
    icon: '🚀',
    id: 'starter',
    title: 'Pack Starter',
    subtitle: 'Création • Statut • Formalités • Contrats • Organisation',
    intro:
      "Créer un business est stimulant mais souvent complexe : statut, banques, contrats, assurances, organisation…",

    actions: [
      'Choix du statut',
      'Formalités de création',
      'Mise en place des partenaires essentiels',
      'Contrats indispensables',
      'Organisation simple et efficace'
    ],

    objectif:
      "Démarrer sur des bases propres, structurées et professionnelles.",

    conseil:
      "Mieux vaut investir un peu au départ que corriger des erreurs un an plus tard.",

    pricing:
      "Forfait de création défini selon le projet, la structure choisie et le niveau d’accompagnement nécessaire."
  },

  {
    icon: '⭐',
    id: 'expert',
    title: 'Pack Expert',
    subtitle: 'Pilotage • Administration • Trésorerie • Coordination',
    intro:
      "Pour les dirigeants qui veulent déléguer une partie du quotidien tout en gardant une vision claire.",

    actions: [
      'Gestion administrative courante',
      'Coordination partenaires',
      'Suivi trésorerie',
      'Organisation claire',
      'Reporting régulier'
    ],

    objectif:
      "Libérer du temps au dirigeant pour les décisions à fort impact.",

    conseil:
      "Un véritable bras droit opérationnel sans embauche interne.",

    pricing:
      "Accompagnement mensuel sur mesure selon le niveau de délégation, le volume de suivi et les responsabilités confiées."
  },

  {
    icon: '🎯',
    id: 'surmesure',
    title: 'Pack Sur-mesure',
    subtitle: 'Flexibilité • Transition • Accompagnement personnalisé',
    intro:
      "Certaines situations ne rentrent pas dans une case : cession, réorganisation, pivot ou contexte atypique.",

    actions: [
      'Diagnostic personnalisé',
      'Objectifs définis ensemble',
      'Plan d’action sur mesure',
      'Accompagnement flexible',
      'Ajustements réguliers'
    ],

    objectif:
      "Construire un accompagnement réellement adapté à votre situation.",

    conseil:
      "Particulièrement utile pour les dirigeants confrontés à une phase de transition.",

    pricing:
      "Rémunération définie selon les objectifs, la complexité de la mission et le niveau d’implication nécessaire."
  }
];
---

<Layout
  title="Services FixBiz — Redressement, trésorerie, rentabilité et accompagnement des dirigeants"
  description="FixBiz accompagne les dirigeants de TPE et PME : trésorerie, rentabilité, organisation, redressement d’entreprise, pilotage et accompagnement."
>

<Nav />

<main>

<section class="services-hero">

  <div class="wrap services-hero__inner">

    <div class="eyebrow">
      Services FixBiz
    </div>

    <h1>
      Packs d’accompagnement et de redressement entreprise
    </h1>

    <p>
      Découvrez nos services d’accompagnement pour aider les dirigeants
      à stabiliser, structurer, développer ou redresser leur entreprise.
    </p>

  </div>

</section>

<section class="packs">

  <div class="wrap packs__grid">

    {packs.map((pack) => (

      <article
        id={pack.id}
        class="pack card"
      >

        <div class="pack__top">

          <div class="pack__icon">
            {pack.icon}
          </div>

          <div>

            <h2>
              {pack.title}
            </h2>

            <div class="pack__subtitle">
              {pack.subtitle}
            </div>

          </div>

        </div>

        <p class="pack__intro">
          {pack.intro}
        </p>

        <div class="pack__section">

          <h3>
            Ce que nous faisons pour vous
          </h3>

          <ul class="pack__list">

            {pack.actions.map((a) => (
              <li>{a}</li>
            ))}

          </ul>

        </div>

        <div class="pack__bloc">

          <strong>
            Objectif
          </strong>

          <p>
            {pack.objectif}
          </p>

        </div>

        <div class="pack__bloc">

          <strong>
            Conseil FixBiz
          </strong>

          <p>
            {pack.conseil}
          </p>

        </div>

        <div class="pack__bloc">

          <strong>
            Combien ça coûte ?
          </strong>

          <p>
            {pack.pricing}
          </p>

        </div>

        <div class="pack__cta">

          <a
            href="/prendre-rdv/"
            class="btn btn--primary"
          >
            Prendre rendez-vous →
          </a>

        </div>

      </article>

    ))}

  </div>

</section>

<section class="final-cta">

  <div class="wrap">

    <div class="final-cta__box card">

      <div>

        <div class="eyebrow">
          Premier échange
        </div>

        <h2>
          Vous ne savez pas quel accompagnement choisir ?
        </h2>

        <p>
          Le premier échange permet de comprendre votre situation
          et de déterminer si une intervention FixBiz peut réellement vous aider.
        </p>

      </div>

      <a
        href="/prendre-rdv/"
        class="btn btn--primary"
      >
        Diagnostic gratuit
      </a>

    </div>

  </div>

</section>

</main>

<Footer />

<Whatsapp />

</Layout>

<style>

.services-hero {
  padding: 138px 0 78px;

  background:
    linear-gradient(
      135deg,
      var(--blue-soft),
      #fff 64%
    );
}

.services-hero__inner {
  max-width: 980px;

  margin: 0 auto;

  text-align: center;
}

.services-hero h1 {
  margin: 1rem 0 1rem;

  font-size:
    clamp(2.4rem, 5vw, 4.3rem);

  line-height: 1.02;

  letter-spacing: -.055em;
}

.services-hero p {
  margin: 0 auto;

  max-width: 760px;

  color: var(--muted);

  line-height: 1.8;

  font-size: 1.05rem;
}

.packs {
  padding: 70px 0;
}

.packs__grid {
  display: grid;

  gap: 28px;
}

.pack {
  padding: 34px;

  border-radius: 28px;

  scroll-margin-top: 110px;
}

.pack__top {
  display: flex;

  gap: 18px;

  align-items: flex-start;
}

.pack__icon {
  width: 62px;
  height: 62px;

  border-radius: 18px;

  background: var(--blue-soft);

  display: flex;

  align-items: center;

  justify-content: center;

  font-size: 1.8rem;

  flex-shrink: 0;
}

.pack h2 {
  margin: 0;

  font-size:
    clamp(1.5rem, 3vw, 2.2rem);

  line-height: 1.1;
}

.pack__subtitle {
  margin-top: 10px;

  color: var(--blue-dark);

  font-size: .9rem;

  font-weight: 700;

  line-height: 1.6;
}

.pack__intro {
  margin: 26px 0;

  color: var(--muted);

  line-height: 1.85;

  font-size: 1rem;
}

.pack__section h3 {
  margin: 0 0 16px;

  font-size: 1rem;
}

.pack__list {
  margin: 0;

  padding: 0;

  list-style: none;

  display: grid;

  gap: 10px;
}

.pack__list li {
  line-height: 1.75;
}

.pack__list li::before {
  content: '✓';

  color: var(--green);

  font-weight: 800;

  margin-right: 10px;
}

.pack__bloc {
  margin-top: 28px;

  padding-top: 22px;

  border-top:
    1px solid rgba(46,127,177,.1);
}

.pack__bloc strong {
  display: block;

  margin-bottom: 10px;

  color: var(--blue-dark);

  font-size: .92rem;

  font-weight: 800;
}

.pack__bloc p {
  margin: 0;

  color: var(--muted);

  line-height: 1.8;
}

.pack__cta {
  margin-top: 32px;
}

.final-cta {
  padding: 0 0 80px;
}

.final-cta__box {
  padding: 36px;

  display: flex;

  justify-content: space-between;

  align-items: center;

  gap: 28px;

  background:
    linear-gradient(
      135deg,
      #fff,
      var(--blue-soft)
    );
}

.final-cta h2 {
  margin: 12px 0 8px;

  font-size:
    clamp(1.8rem, 3vw, 2.4rem);

  line-height: 1.15;

  max-width: 620px;
}

.final-cta p {
  margin: 0;

  color: var(--muted);

  line-height: 1.8;

  max-width: 720px;
}

@media (max-width: 820px) {

  .services-hero {
    padding: 120px 0 62px;
  }

  .pack {
    padding: 26px;
  }

  .final-cta__box {
    flex-direction: column;

    align-items: flex-start;
  }

}

</style>