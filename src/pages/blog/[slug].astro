---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Whatsapp from '../../components/Whatsapp.astro';

import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');

const relatedPosts = allPosts
  .filter((item) =>
    item.id !== post.id &&
    item.data.category === post.data.category
  )
  .sort((a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
  )
  .slice(0, 3);

const slug = (item) => `/blog/${item.id.replace(/\.md$/, '')}/`;
---

<Layout title={post.data.title} description={post.data.description}>
  <Nav />

  <main class="article">

    <section class="article__hero">
      <div class="wrap article__hero-grid">

        <div class="article__intro">
          <div class="article__meta">{post.data.category}</div>

          <h1>{post.data.title}</h1>

          <p class="article__desc">{post.data.description}</p>

          <div class="article__actions">
            <a href="/prendre-rdv/" class="btn btn--primary">
              Parler de ma situation
            </a>

            <a href="/blog/" class="article__back">
              Voir tous les articles
            </a>
          </div>
        </div>

        {
          post.data.image && (
            <div class="article__image-wrap">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="article__image"
              />
            </div>
          )
        }

      </div>
    </section>

    <section class="article__section">
      <div class="wrap article__layout">

        <aside class="article__side">
          <div class="side-card">
            <span>FixBiz</span>
            <h3>Besoin de recul ?</h3>
            <p>
              Un regard extérieur permet souvent de clarifier rapidement les priorités.
            </p>
            <a href="/prendre-rdv/">Faire le point →</a>
          </div>
        </aside>

        <article class="article__content">
          <Content />
        </article>

      </div>
    </section>

    <section class="article__cta-section">
      <div class="wrap">
        <div class="article__cta">
          <span>Situation compliquée ?</span>

          <h2>Vous vous reconnaissez dans cet article ?</h2>

          <p>
            Trésorerie tendue, perte de visibilité, pression permanente,
            difficultés de rentabilité ou surcharge du dirigeant : un premier
            échange permet souvent d’identifier les priorités.
          </p>

          <a href="/prendre-rdv/" class="btn btn--primary">
            Contacter FixBiz
          </a>
        </div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="wrap">
          <div class="related-head">
            <span>À lire aussi</span>
            <h2>Articles liés</h2>
          </div>

          <div class="related-grid">
            {relatedPosts.map((item) => (
              <a href={slug(item)} class="related-card">
                {item.data.image && (
                  <img src={item.data.image} alt={item.data.title} loading="lazy" />
                )}

                <div>
                  <span>{item.data.category}</span>
                  <h3>{item.data.title}</h3>
                  <p>{item.data.description}</p>
                  <strong>Lire l’article →</strong>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer />
  <Whatsapp />
</Layout>

<style>
  .article__hero {
    padding: 136px 0 76px;
    background:
      radial-gradient(circle at 12% 18%, #dff1fb 0, transparent 34%),
      linear-gradient(135deg, var(--blue-soft), #ffffff 70%);
  }

  .article__hero-grid {
    display: grid;
    grid-template-columns: 1fr .9fr;
    gap: 46px;
    align-items: center;
  }

  .article__meta {
    display: inline-flex;
    width: fit-content;
    padding: .45rem .85rem;
    border-radius: 999px;
    background: rgba(46,127,177,.1);
    color: var(--blue-dark);
    font-size: .78rem;
    font-weight: 900;
    margin-bottom: 1.1rem;
  }

  .article__hero h1 {
    max-width: 820px;
    font-size: clamp(2.25rem, 4.7vw, 4.35rem);
    line-height: 1.03;
    letter-spacing: -.055em;
    color: #163047;
    margin: 0 0 1.25rem;
  }

  .article__desc {
    max-width: 700px;
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.05rem;
    margin: 0;
  }

  .article__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .article__back {
    color: var(--blue);
    font-weight: 850;
    text-decoration: none;
  }

  .article__image-wrap {
    overflow: hidden;
    border-radius: 32px;
    box-shadow: 0 24px 60px rgba(16,45,70,.15);
    background: #eef6fb;
  }

  .article__image {
    width: 100%;
    height: 430px;
    object-fit: cover;
    display: block;
  }

  .article__section {
    padding: 72px 0 50px;
    background: #ffffff;
  }

  .article__layout {
    display: grid;
    grid-template-columns: 260px minmax(0, 860px);
    gap: 34px;
    align-items: start;
  }

  .article__side {
    position: sticky;
    top: 105px;
  }

  .side-card {
    padding: 24px;
    border-radius: 24px;
    background: linear-gradient(135deg, #eff6fb 0%, #ffffff 100%);
    border: 1px solid rgba(46,127,177,.13);
    box-shadow: 0 14px 34px rgba(16,45,70,.06);
  }

  .side-card span,
  .article__cta span,
  .related-head span,
  .related-card span {
    color: var(--blue);
    font-size: .76rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .side-card h3 {
    margin: .7rem 0 .6rem;
    color: #163047;
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .side-card p {
    color: var(--muted);
    line-height: 1.65;
    font-size: .94rem;
  }

  .side-card a {
    display: inline-block;
    margin-top: .8rem;
    color: var(--blue);
    font-weight: 900;
    text-decoration: none;
  }

  .article__content {
    max-width: 860px;
    background: #fff;
    border-radius: 30px;
    padding: 48px;
    border: 1px solid rgba(20,65,95,.08);
    box-shadow: 0 18px 40px rgba(16,45,70,.05);
    color: #355066;
    line-height: 1.9;
    font-size: 1.02rem;
  }

  .article__content h1,
  .article__content h2,
  .article__content h3 {
    color: #163047;
    line-height: 1.15;
    letter-spacing: -.025em;
  }

  .article__content h1 {
    font-size: 2rem;
    margin-top: 0;
  }

  .article__content h2 {
    margin-top: 2.8rem;
    margin-bottom: 1rem;
    font-size: 1.65rem;
  }

  .article__content h3 {
    margin-top: 2rem;
    font-size: 1.28rem;
  }

  .article__content p {
    margin-bottom: 1.3rem;
  }

  .article__content ul {
    padding-left: 1.2rem;
    margin-bottom: 1.5rem;
  }

  .article__content li {
    margin-bottom: .7rem;
  }

  .article__content a {
    color: var(--blue);
    font-weight: 800;
  }

  .article__cta-section {
    padding: 24px 0 64px;
    background: #fff;
  }

  .article__cta {
    max-width: 860px;
    margin-left: 294px;
    padding: 42px;
    border-radius: 30px;
    background:
      linear-gradient(135deg, #eff6fb 0%, #ffffff 100%);
    border: 1px solid rgba(46,127,177,.12);
    box-shadow: 0 18px 40px rgba(16,45,70,.055);
  }

  .article__cta h2 {
    margin: .7rem 0 1rem;
    color: #163047;
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    letter-spacing: -.035em;
    line-height: 1.1;
  }

  .article__cta p {
    max-width: 680px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.6rem;
  }

  .related-section {
    padding: 70px 0 94px;
    background: #f7fbfe;
  }

  .related-head {
    margin-bottom: 26px;
  }

  .related-head h2 {
    margin: .6rem 0 0;
    color: #163047;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    letter-spacing: -.04em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .related-card {
    overflow: hidden;
    border-radius: 26px;
    background: #fff;
    border: 1px solid rgba(20,65,95,.08);
    text-decoration: none;
    box-shadow: 0 14px 34px rgba(16,45,70,.055);
    transition: transform .22s ease, box-shadow .22s ease;
  }

  .related-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 22px 48px rgba(16,45,70,.1);
  }

  .related-card img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    display: block;
  }

  .related-card div {
    padding: 24px;
  }

  .related-card h3 {
    margin: .75rem 0 .75rem;
    color: #163047;
    line-height: 1.18;
    font-size: 1.18rem;
    letter-spacing: -.02em;
  }

  .related-card p {
    color: var(--muted);
    line-height: 1.65;
    font-size: .93rem;
  }

  .related-card strong {
    display: inline-block;
    margin-top: .7rem;
    color: var(--blue);
    font-size: .93rem;
  }

  @media (max-width: 980px) {
    .article__hero-grid,
    .article__layout {
      grid-template-columns: 1fr;
    }

    .article__side {
      position: static;
      order: 2;
    }

    .article__content {
      order: 1;
    }

    .article__cta {
      margin-left: 0;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .article__image {
      height: 320px;
    }
  }

  @media (max-width: 768px) {
    .article__hero {
      padding: 118px 0 58px;
    }

    .article__content {
      padding: 30px;
      border-radius: 24px;
    }

    .article__cta {
      padding: 30px;
    }

    .article__image {
      height: 260px;
      border-radius: 22px;
    }
  }
</style>