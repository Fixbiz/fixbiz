---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Whatsapp from '../../components/Whatsapp.astro';

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

posts.sort((a, b) =>
  new Date(b.data.date).getTime() -
  new Date(a.data.date).getTime()
);

const slug = (post) => `/blog/${post.id.replace(/\.md$/, '')}/`;

const byCategory = (categories) =>
  posts.filter((post) => categories.includes(post.data.category));

const guides = byCategory(['Guide']);
const redressement = byCategory(['Redressement', 'Liquidation']);
const tresorerie = byCategory(['Trésorerie', 'Financement']);
const rentabilite = byCategory(['Rentabilité', 'Croissance']);
const dirigeant = byCategory(['Dirigeant', 'Organisation', 'Pilotage']);
const cession = byCategory(['Cession']);

const sections = [
  {
    id: 'redressement',
    title: 'Entreprises en difficulté',
    intro: 'Comprendre les signaux d’alerte, les erreurs à éviter et les premières actions à mettre en place avant que la situation ne devienne critique.',
    posts: redressement,
  },
  {
    id: 'tresorerie',
    title: 'Trésorerie, banque & financement',
    intro: 'Découvert bancaire, refus de crédit, retards de paiement, pression bancaire : les sujets essentiels pour reprendre de la visibilité financière.',
    posts: tresorerie,
  },
  {
    id: 'rentabilite',
    title: 'Rentabilité & croissance',
    intro: 'Comprendre pourquoi une entreprise peut faire du chiffre sans gagner d’argent, perdre sa rentabilité ou grandir trop vite.',
    posts: rentabilite,
  },
  {
    id: 'dirigeant',
    title: 'Dirigeant, organisation & pilotage',
    intro: 'Charge mentale, urgences permanentes, organisation fragile : les contenus pour reprendre du recul et retrouver une entreprise plus pilotable.',
    posts: dirigeant,
  },
  {
    id: 'cession',
    title: 'Cession & valorisation',
    intro: 'Améliorer la performance, structurer l’entreprise et renforcer sa valeur avant une vente ou une transmission.',
    posts: cession,
  },
].filter((section) => section.posts.length > 0);
---

<Layout
  title="Blog — FixBiz"
  description="Conseils pratiques pour dirigeants : trésorerie, redressement, organisation, pilotage et cession d'entreprise."
>
  <Nav />

  <main class="blog">

    <section class="blog-hero">
      <div class="wrap hero-inner">
        <div class="eyebrow">Blog FixBiz</div>

        <h1>Conseils pratiques pour dirigeants de PME.</h1>

        <p>
          Trésorerie, restructuration, organisation, rentabilité,
          pression dirigeant, croissance et situations difficiles.
        </p>

        <div class="problem-nav">
          <a href="#redressement">🚨 Entreprise en difficulté</a>
          <a href="#tresorerie">💰 Trésorerie & banque</a>
          <a href="#rentabilite">📈 Rentabilité</a>
          <a href="#dirigeant">🧠 Dirigeant & organisation</a>
        </div>
      </div>
    </section>

    {guides.length > 0 && (
      <section class="featured-section">
        <div class="wrap">
          <div class="section-head">
            <span>Guides complets</span>
            <h2>Commencer par les contenus essentiels</h2>
            <p>
              Des guides longs pour comprendre rapidement les signaux d’alerte,
              les priorités et les premières actions possibles.
            </p>
          </div>

          <div class="featured-grid">
            {guides.slice(0, 3).map((post) => (
              <a href={slug(post)} class="featured-card">
                {post.data.image && (
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                )}

                <div class="featured-content">
                  <span>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <strong>Lire le guide →</strong>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="choice-section">
      <div class="wrap">
        <div class="choice-box">
          <div>
            <span class="choice-kicker">Votre situation</span>
            <h2>Quel problème cherchez-vous à comprendre ?</h2>
          </div>

          <div class="choice-grid">
            <a href="#redressement">🚨 Situation critique</a>
            <a href="#tresorerie">💰 Trésorerie tendue</a>
            <a href="#rentabilite">📈 Rentabilité faible</a>
            <a href="#dirigeant">🧠 Trop de pression</a>
          </div>
        </div>
      </div>
    </section>

    {sections.map((section) => (
      <section class="blog-cluster" id={section.id}>
        <div class="wrap">
          <div class="section-head">
            <span>{section.title}</span>
            <h2>{section.title}</h2>
            <p>{section.intro}</p>
          </div>

          <div class="cluster-grid">
            {section.posts.map((post) => (
              <a href={slug(post)} class="post">
                {post.data.image && (
                  <div class="post-image">
                    <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  </div>
                )}

                <div class="post-body">
                  <span>{post.data.category}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <strong>Lire l’article →</strong>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

  </main>

  <Footer />
  <Whatsapp />
</Layout>

<style>
  .blog-hero {
    padding: 140px 0 78px;
    background:
      radial-gradient(circle at 12% 18%, #dff1fb 0, transparent 34%),
      linear-gradient(135deg, var(--blue-soft) 0%, #fff 68%);
  }

  .hero-inner {
    max-width: 1160px;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .45rem .9rem;
    border-radius: 999px;
    background: rgba(46,127,177,.1);
    color: var(--blue-dark);
    font-size: .78rem;
    font-weight: 850;
  }

  .blog-hero h1 {
    max-width: 860px;
    margin: 1.1rem auto;
    font-size: clamp(2.35rem, 5vw, 4.7rem);
    letter-spacing: -.06em;
    line-height: 1.02;
    color: #163047;
  }

  .blog-hero p {
    max-width: 740px;
    margin: 0 auto;
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.06rem;
  }

  .problem-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: .8rem;
    margin-top: 2rem;
  }

  .problem-nav a,
  .choice-grid a {
    text-decoration: none;
    padding: .82rem 1rem;
    border-radius: 999px;
    background: #fff;
    color: #163047;
    border: 1px solid rgba(20,65,95,.08);
    box-shadow: 0 10px 26px rgba(16,45,70,.06);
    font-size: .92rem;
    font-weight: 800;
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .problem-nav a:hover,
  .choice-grid a:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 34px rgba(16,45,70,.1);
  }

  .featured-section {
    padding: 76px 0 42px;
    background: #fff;
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .section-head span,
  .choice-kicker {
    color: var(--blue);
    font-size: .78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .section-head h2,
  .choice-box h2 {
    margin: .55rem 0 .7rem;
    color: #163047;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.08;
    letter-spacing: -.04em;
  }

  .section-head p {
    color: var(--muted);
    line-height: 1.75;
    margin: 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 42% 1fr;
    overflow: hidden;
    min-height: 330px;
    border-radius: 32px;
    background: #f7fbfe;
    border: 1px solid rgba(20,65,95,.08);
    text-decoration: none;
    box-shadow: 0 18px 44px rgba(16,45,70,.08);
    transition: transform .24s ease, box-shadow .24s ease;
  }

  .featured-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 26px 60px rgba(16,45,70,.13);
  }

  .featured-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-content {
    padding: 38px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-content span,
  .post span {
    width: fit-content;
    padding: .4rem .75rem;
    border-radius: 999px;
    background: rgba(46,127,177,.1);
    color: var(--blue-dark);
    font-weight: 850;
    font-size: .75rem;
    margin-bottom: 1rem;
  }

  .featured-content h3 {
    margin: 0 0 1rem;
    color: #163047;
    font-size: clamp(1.55rem, 2.8vw, 2.45rem);
    line-height: 1.08;
    letter-spacing: -.04em;
  }

  .featured-content p {
    color: var(--muted);
    line-height: 1.75;
    margin: 0 0 1.3rem;
  }

  .featured-content strong,
  .post strong {
    margin-top: auto;
    color: var(--blue);
    font-size: .95rem;
    font-weight: 900;
  }

  .choice-section {
    padding: 34px 0 44px;
    background: #fff;
  }

  .choice-box {
    padding: 34px;
    border-radius: 30px;
    background:
      linear-gradient(135deg, #eef8fd 0%, #fff 70%);
    border: 1px solid rgba(46,127,177,.12);
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 24px;
    align-items: center;
  }

  .choice-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .8rem;
  }

  .blog-cluster {
    padding: 54px 0;
    background: #fff;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .post {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 430px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(20,65,95,.08);
    text-decoration: none;
    box-shadow: 0 14px 34px rgba(16,45,70,.055);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
  }

  .post:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 48px rgba(16,45,70,.11);
    border-color: rgba(46,127,177,.22);
  }

  .post-image {
    height: 190px;
    overflow: hidden;
    background: #eef6fb;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .35s ease;
  }

  .post:hover .post-image img {
    transform: scale(1.06);
  }

  .post-body {
    padding: 26px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post h3 {
    margin: 0 0 .9rem;
    font-size: clamp(1.2rem, 1.7vw, 1.55rem);
    line-height: 1.18;
    letter-spacing: -.025em;
    color: #163047;
  }

  .post p {
    color: var(--muted);
    line-height: 1.68;
    margin: 0 0 1.4rem;
    font-size: .94rem;
  }

  @media (max-width: 980px) {
    .featured-card,
    .choice-box {
      grid-template-columns: 1fr;
    }

    .featured-card {
      min-height: auto;
    }

    .featured-card img {
      height: 260px;
    }

    .cluster-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .blog-hero {
      padding: 118px 0 58px;
    }

    .featured-section {
      padding: 52px 0 30px;
    }

    .cluster-grid {
      grid-template-columns: 1fr;
    }

    .choice-box {
      padding: 26px;
    }

    .post {
      min-height: auto;
    }

    .post-image {
      height: 210px;
    }
  }
</style>