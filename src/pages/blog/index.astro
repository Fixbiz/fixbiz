---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Whatsapp from '../../components/Whatsapp.astro';

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

posts.sort((a, b) =>
  new Date(b.data.date).getTime() -
  new Date(a.data.date).getTime()
);
---

<Layout
  title="Blog — FixBiz"
  description="Conseils pratiques pour dirigeants : trésorerie, redressement, organisation, pilotage et cession d'entreprise."
>

  <Nav />

  <main class="blog">

    <section class="blog-hero">

      <div class="wrap">

        <div class="eyebrow">
          Blog FixBiz
        </div>

        <h1>
          Conseils pratiques pour dirigeants.
        </h1>

        <p>
          Trésorerie, restructuration, organisation,
          rentabilité, croissance et situations difficiles.
        </p>

      </div>

    </section>

    <section class="blog-section">

      <div class="wrap blog-grid">

        {posts.map((post) => (

          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}/`}
            class="card post"
          >

            <span>
              {post.data.category}
            </span>

            <h2>
              {post.data.title}
            </h2>

            <p>
              {post.data.description}
            </p>

            <strong>
              Lire l’article →
            </strong>

          </a>

        ))}

      </div>

    </section>

  </main>

  <Footer />
  <Whatsapp />

</Layout>

<style>
  .blog-hero {
    padding: 140px 0 76px;
    background:
      radial-gradient(circle at 15% 20%, #dff1fb 0, transparent 34%),
      linear-gradient(135deg, var(--blue-soft) 0%, #fff 65%);
  }

  .blog-hero .wrap {
    max-width: 1160px;
  }

  .blog-hero h1 {
    max-width: 780px;
    margin: 1rem 0;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    letter-spacing: -.055em;
    line-height: 1.02;
    color: #163047;
  }

  .blog-hero p {
    max-width: 680px;
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .blog-section {
    padding: 74px 0 96px;
    background: #fff;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
  }

  .post {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 260px;
    padding: 34px;
    border-radius: 28px;
    background: linear-gradient(180deg, #ffffff 0%, #f7fbfe 100%);
    border: 1px solid rgba(20,65,95,.08);
    text-decoration: none;
    box-shadow: 0 14px 34px rgba(16,45,70,.05);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
  }

  .post:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 48px rgba(16,45,70,.1);
    border-color: rgba(46,127,177,.22);
  }

  .post span {
    width: fit-content;
    padding: .38rem .72rem;
    border-radius: 999px;
    background: rgba(46,127,177,.09);
    color: var(--blue-dark);
    font-weight: 800;
    font-size: .76rem;
    margin-bottom: 1.1rem;
  }

  .post h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    line-height: 1.18;
    letter-spacing: -.025em;
    color: #163047;
  }

  .post p {
    color: var(--muted);
    line-height: 1.75;
    margin: 0 0 1.6rem;
    font-size: .96rem;
  }

  .post strong {
    margin-top: auto;
    color: var(--blue);
    font-size: .94rem;
    font-weight: 800;
  }

  @media (max-width: 850px) {
    .blog-hero {
      padding: 118px 0 60px;
    }

    .blog-section {
      padding: 52px 0 76px;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .post {
      min-height: auto;
      padding: 28px;
    }
  }
</style>