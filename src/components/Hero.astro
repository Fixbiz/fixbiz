
---
---

<section class="hero">
  <div class="wrap hero__inner">
    <div class="hero__copy fade">
      <div class="eyebrow">
        Accompagnement opérationnel pour dirigeants de TPE & PME
      </div>

      <h1>
        Moins de stress,<br />
        plus de bizness.
      </h1>

      <p class="hero__lead">
        FixBiz aide les dirigeants à remettre l’entreprise sur les rails,
        améliorer les performances ou préparer une vente dans les meilleures conditions.
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href="/prendre-rdv/">
          Faire le point gratuitement →
        </a>

        <a class="btn btn--ghost" href="/nos-services/">
          Découvrir les services
        </a>
      </div>

      <div class="hero__proof">
        <div>
          <strong>Entreprise en difficulté</strong>
          <span>trésorerie, organisation, pression</span>
        </div>

        <div>
          <strong>Performance</strong>
          <span>rentabilité, efficacité, pilotage</span>
        </div>

        <div>
          <strong>Préparation à la vente</strong>
          <span>valorisation et structuration</span>
        </div>
      </div>
    </div>

    <div class="hero__visual fade">
      <img
        src="/hero-fixbiz.png"
        alt="Accompagnement opérationnel des dirigeants de PME"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 92px 0 54px;
    background:
      radial-gradient(circle at 15% 20%, #dff1fb 0, transparent 34%),
      linear-gradient(135deg, var(--blue-soft) 0%, #fff 62%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.08fr .82fr;
    gap: 54px;
    align-items: center;
  }

  .hero__copy h1 {
    margin: 1rem 0 .95rem;
    font-size: clamp(2.35rem, 4.4vw, 4.25rem);
    line-height: 1;
    letter-spacing: -.045em;
    font-weight: 780;
    color: #163047;
    max-width: 680px;
  }

  .hero__lead {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.62;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .85rem;
    margin-top: 1.55rem;
  }

  .hero__proof {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 1.55rem;
  }

  .hero__proof div {
    padding: 12px 13px;
    border-left: 3px solid var(--blue);
    background: rgba(255, 255, 255, .62);
    border-radius: 14px;
  }

  .hero__proof strong {
    display: block;
    font-size: .88rem;
    color: var(--ink);
    line-height: 1.25;
  }

  .hero__proof span {
    display: block;
    color: var(--muted);
    font-size: .75rem;
    line-height: 1.35;
    margin-top: .25rem;
  }

  .hero__visual {
    position: relative;
  }

  .hero__visual img {
    width: 100%;
    aspect-ratio: 4 / 3.15;
    object-fit: cover;
    border-radius: 26px;
    box-shadow: var(--shadow);
  }

  @media (max-width: 900px) {
    .hero {
      padding: 84px 0 46px;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .hero__copy h1 {
      font-size: clamp(2.25rem, 10.5vw, 3.5rem);
      line-height: 1;
      max-width: 100%;
    }

    .hero__lead {
      font-size: 1rem;
      line-height: 1.55;
    }

    .hero__actions {
      flex-direction: column;
      margin-top: 1.35rem;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    .hero__proof {
      grid-template-columns: 1fr;
      margin-top: 1.3rem;
    }

    .hero__visual img {
      border-radius: 22px;
      aspect-ratio: 4 / 3;
    }
  }
</style>