---
const posts = Object.entries(
  import.meta.glob("../content/blog/*.{md,mdx}", {
    eager: true,
  })
);

const latestPosts = posts
  .map(([path, post]) => {
    const slug = path
      .split("/")
      .pop()
      .replace(".mdx", "")
      .replace(".md", "");

    return {
      ...post,
      slug,
      url: `/blog/${slug}/`,
    };
  })
  .filter((post) => post.frontmatter)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime()
  )
  .slice(0, 3);
---

<section class="blog-preview">
  <div class="container">
    <div class="blog-preview__head">
      <span class="eyebrow">Conseils dirigeants</span>

      <h2>Comprendre les signaux avant qu’il ne soit trop tard.</h2>

      <p>
        Trésorerie tendue, pression bancaire, rentabilité faible,
        surcharge du dirigeant : des articles concrets pour reprendre de la visibilité.
      </p>
    </div>

    <div class="blog-preview__grid">
      {latestPosts.map((post, index) => (
        <article class={`blog-preview__card ${index === 0 ? "is-featured" : ""}`}>
          <a href={post.url} class="blog-preview__image">
            <img
              src={post.frontmatter.image}
              alt={post.frontmatter.title}
              loading="lazy"
            />
          </a>

          <div class="blog-preview__content">
            <div class="blog-preview__meta">
              <span>{post.frontmatter.category}</span>
              <small>Conseil pratique</small>
            </div>

            <h3>
              <a href={post.url}>{post.frontmatter.title}</a>
            </h3>

            <p>{post.frontmatter.description}</p>

            <a href={post.url} class="blog-preview__link">
              Lire l’article →
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="blog-preview__footer">
      <a href="/blog/" class="blog-preview__cta">
        Voir tous les articles
      </a>
    </div>
  </div>
</section>

<style>
.blog-preview {
  padding: 115px 0;
  background:
    radial-gradient(circle at 12% 18%, rgba(46,127,177,.12), transparent 32%),
    linear-gradient(180deg, #ffffff 0%, #f7fbfe 100%);
}

.blog-preview .container {
  width: min(1160px, calc(100% - 48px));
  margin: 0 auto;
}

.blog-preview__head {
  max-width: 780px;
  margin: 0 auto 56px;
  text-align: center;
}

.blog-preview__head h2 {
  margin: 1rem 0 .9rem;
  font-size: clamp(2rem, 4vw, 3.35rem);
  line-height: 1.06;
  letter-spacing: -.05em;
  color: var(--ink);
  font-weight: 850;
}

.blog-preview__head p {
  margin: 0 auto;
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.75;
  max-width: 700px;
}

.blog-preview__grid {
  display: grid;
  grid-template-columns: 1.15fr .9fr .9fr;
  gap: 26px;
  align-items: stretch;
}

.blog-preview__card {
  background: #fff;
  border-radius: 30px;
  overflow: hidden;
  border: 1px solid rgba(46,127,177,.12);
  box-shadow: 0 18px 45px rgba(16,45,70,.08);
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
}

.blog-preview__card:hover {
  transform: translateY(-6px);
  box-shadow: 0 26px 64px rgba(16,45,70,.13);
  border-color: rgba(46,127,177,.24);
}

.blog-preview__image {
  display: block;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: #eff6fb;
}

.blog-preview__card.is-featured .blog-preview__image {
  aspect-ratio: 16 / 11;
}

.blog-preview__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .35s ease;
}

.blog-preview__card:hover .blog-preview__image img {
  transform: scale(1.06);
}

.blog-preview__content {
  padding: 1.55rem;
}

.blog-preview__card.is-featured .blog-preview__content {
  padding: 1.8rem;
}

.blog-preview__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
  font-size: .78rem;
  color: var(--muted);
}

.blog-preview__meta span {
  display: inline-flex;
  padding: .35rem .7rem;
  border-radius: 999px;
  background: rgba(46,127,177,.1);
  color: var(--blue-dark);
  font-weight: 900;
}

.blog-preview__meta small {
  font-size: .75rem;
  color: var(--muted);
  font-weight: 700;
}

.blog-preview__content h3 {
  margin: 0 0 .75rem;
  font-size: 1.18rem;
  line-height: 1.22;
  letter-spacing: -.025em;
}

.blog-preview__card.is-featured h3 {
  font-size: clamp(1.45rem, 2.2vw, 2rem);
  line-height: 1.12;
}

.blog-preview__content h3 a {
  color: var(--ink);
  text-decoration: none;
}

.blog-preview__content h3 a:hover {
  color: var(--blue);
}

.blog-preview__content p {
  margin: 0 0 1.25rem;
  color: var(--muted);
  font-size: .94rem;
  line-height: 1.7;
}

.blog-preview__link {
  color: var(--blue);
  font-weight: 900;
  text-decoration: none;
}

.blog-preview__link:hover {
  text-decoration: underline;
}

.blog-preview__footer {
  margin-top: 44px;
  text-align: center;
}

.blog-preview__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 1.55rem;
  border-radius: 999px;
  background: var(--blue);
  color: #fff;
  font-weight: 850;
  text-decoration: none;
  box-shadow: 0 14px 30px rgba(46,127,177,.22);
  transition: transform .2s ease, opacity .2s ease;
}

.blog-preview__cta:hover {
  transform: translateY(-2px);
  opacity: .92;
}

@media (max-width: 980px) {
  .blog-preview {
    padding: 86px 0;
  }

  .blog-preview__grid {
    grid-template-columns: 1fr;
  }

  .blog-preview__card.is-featured .blog-preview__image,
  .blog-preview__image {
    aspect-ratio: 16 / 10;
  }
}

@media (max-width: 700px) {
  .blog-preview .container {
    width: min(100% - 28px, 1160px);
  }

  .blog-preview__content,
  .blog-preview__card.is-featured .blog-preview__content {
    padding: 1.35rem;
  }
}
</style>