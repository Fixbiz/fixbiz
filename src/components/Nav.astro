</style>

<script>

  const toggle =
    document.querySelector('.nav__toggle');

  const links =
    document.querySelector('.nav__links');

  toggle?.addEventListener('click', () => {

    const open =
      links?.classList.toggle('open');

    toggle.setAttribute(
      'aria-expanded',
      String(Boolean(open))
    );

  });

</script>