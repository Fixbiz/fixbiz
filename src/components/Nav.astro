<style>

  .nav {
    position: fixed;

    inset: 0 0 auto 0;

    z-index: 100;

    background:
      rgba(255,255,255,.96);

    backdrop-filter: blur(14px);

    border-bottom: 1px solid var(--line);
  }

  .nav__inner {
    max-width: var(--max);

    height: 72px;

    margin: 0 auto;

    padding: 0 48px;

    display: flex;

    align-items: center;

    justify-content: space-between;

    gap: 24px;
  }

  .nav__logo {
    display: flex;

    align-items: center;

    cursor: pointer;

    transition: opacity .2s ease;
  }

  .nav__logo:hover {
    opacity: .82;
  }

  .nav__logo img {
    height: 38px;

    width: auto;
  }

  .nav__links {
    display: flex;

    align-items: center;

    gap: 1.45rem;

    list-style: none;

    margin: 0;

    padding: 0;
  }

  .nav__links a {
    color: var(--muted);

    font-size: .92rem;

    font-weight: 750;

    transition:
      color .18s ease,
      opacity .18s ease,
      transform .18s ease;
  }

  .nav__links a:hover {
    color: var(--blue-dark);

    transform: translateY(-1px);
  }

  .nav__cta {
    background: var(--blue);

    color: #fff !important;

    padding: .68rem 1.05rem;

    border-radius: 12px;

    box-shadow:
      0 8px 22px rgba(46,127,177,.22);
  }

  .nav__cta:hover {
    background: var(--blue-dark);

    color: #fff !important;
  }

  .nav__toggle {
    display: none;

    border: 1px solid var(--line);

    background: #fff;

    border-radius: 10px;

    padding: .45rem .7rem;

    color: var(--ink);

    cursor: pointer;
  }

  @media (max-width: 920px) {

    .nav__inner {
      padding: 0 20px;
    }

    .nav__toggle {
      display: block;
    }

    .nav__links {
      display: none;

      position: absolute;

      top: 72px;

      left: 16px;

      right: 16px;

      padding: 16px;

      border: 1px solid var(--line);

      border-radius: 18px;

      background: #fff;

      box-shadow: var(--shadow);

