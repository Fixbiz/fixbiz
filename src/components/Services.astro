---
const services = [
  {
    id: 'resilience',
    tag: 'Urgence · Trésorerie',
    title: 'Pack Résilience',
    text: "Pour les situations où il faut agir vite : trésorerie tendue, dettes, créanciers, perte de visibilité ou risque de blocage.",
    points: [
      'Diagnostic rapide',
      'Priorités 7 / 30 / 90 jours',
      'Plan de redressement'
    ],
    featured: true
  },

  {
    id: 'performance',
    tag: 'Rentabilité',
    title: 'Pack Performance',
    text: "Pour les entreprises qui fonctionnent mais manquent de structure, de marge ou de visibilité dans le pilotage quotidien.",
    points: [
      'Analyse des marges',
      'Process simples',
      'Reporting utile'
    ]
  },

  {
    id: 'soutien',
    tag: 'Dirigeant',
    title: 'Pack Soutien',
    text: "Pour les dirigeants seuls face aux décisions, aux priorités et à la pression quotidienne.",
    points: [
      'Point régulier',
      'Aide à la décision',
      'Priorités claires'
    ]
  },

  {
    id: 'starter',
    tag: 'Création',
    title: 'Pack Starter',
    text: "Pour lancer un projet sur des bases propres : structure, partenaires, contrats, formalités et organisation initiale.",
    points: [
      'Statut adapté',
      'Formalités',
      'Organisation'
    ]
  },

  {
    id: 'expert',
    tag: 'Bras droit',
    title: 'Pack Expert',
    text: "Pour déléguer une partie du pilotage administratif, financier et opérationnel sans recruter en interne.",
    points: [
      'Suivi trésorerie',
      'Coordination',
      'Reporting'
    ]
  },

  {
    id: 'surmesure',
    tag: 'Mission ciblée',
    title: 'Pack Sur-mesure',
    text: "Pour les situations atypiques : cession, transition, réorganisation, crise ponctuelle ou besoin spécifique.",
    points: [
      'Objectifs précis',
      'Format flexible',
      'Suivi adapté'
    ]
  }
];
---

<section class="section services" id="services">

  <div class="wrap">

    <div class="section-head section-head--center fade">

      <div class="eyebrow">
        Services FixBiz
      </div>

      <h2 class="section-title section-title--small">
        Packs d’accompagnement et de redressement entreprise.
      </h2>

      <p class="section-sub">
        FixBiz accompagne les dirigeants de TPE et PME pour créer, organiser,
        développer ou redresser leur entreprise selon leur situation réelle.
      </p>

    </div>

    <div class="services__grid fade">

      {services.map((s) => (

        <a
          href={`/nos-services/#${s.id}`}
          class:list={[
            'services__card',
            'card',
            { 'services__card--featured': s.featured }
          ]}
        >

          <span class="services__tag">
            {s.tag}
          </span>

          <h3>
            {s.title}
          </h3>

          <p>
            {s.text}
          </p>

          <ul>

            {s.points.map((p) => (
              <li>{p}</li>
            ))}

          </ul>

        </a>

      ))}

    </div>

    <div class="services__bottom fade">

      <a
        href="/nos-services/"
        class="btn btn--primary"
      >
        Voir tous les services
      </a>

      <a
        href="/prendre-rdv/"
        class="btn btn--ghost"
      >
        Parler de ma situation
      </a>

    </div>

  </div>

</section>

<style>

  .services {
    background: #fff;
  }

  .services__grid {
    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 18px;
  }

  .services__card {
    padding: 24px;

    display: flex;

    flex-direction: column;

    min-height: 330px;

    text-decoration: none;

    color: inherit;

    cursor: pointer;

    position: relative;

    overflow: hidden;

    transition:
      transform .22s ease,
      box-shadow .22s ease,
      border-color .22s ease,
      background .22s ease;
  }

  .services__card::before {
    content: '';

    position: absolute;

    inset: 0;

    background:
      linear-gradient(
        135deg,
        rgba(46,127,177,.08),
        transparent 45%
      );

    opacity: 0;

    transition: opacity .25s ease;

    pointer-events: none;
  }

  .services__card:hover::before {
    opacity: 1;
  }

  .services__card:hover {
    transform: translateY(-8px);

    border-color:
      rgba(46,127,177,.45);

    background:
      linear-gradient(
        180deg,
        #ffffff 0%,
        #eef8ff 100%
      );

    box-shadow:
      0 26px 60px rgba(46,127,177,.18);
  }

  .services__card:hover h3 {
    color: var(--blue);
  }

  .services__card:hover .services__tag {
    background: var(--blue);

    color: #fff;
  }

  .services__card--featured {
    border-color: rgba(46,127,177,.45);

    background:
      linear-gradient(
        180deg,
        #fff 0%,
        #f2f9fd 100%
      );
  }

  .services__tag {
    width: fit-content;

    padding: .32rem .68rem;

    border-radius: 999px;

    background: var(--blue-soft);

    color: var(--blue-dark);

    font-size: .72rem;

    font-weight: 800;

    transition:
      background .22s ease,
      color .22s ease;
  }

  .services__card h3 {
    margin: 18px 0 8px;

    font-size: 1.16rem;

    line-height: 1.25;

    color: #163047;

    transition: color .22s ease;
  }

  .services__card p {
    margin: 0;

    color: var(--muted);

    font-size: .92rem;

    line-height: 1.7;
  }

  .services__card ul {
    margin: 18px 0 0;

    padding: 0;

    list-style: none;

    display: grid;

    gap: 8px;
  }

  .services__card li {
    color: var(--ink);

    font-size: .88rem;
  }

  .services__card li::before {
    content: '✓';

    color: var(--green);

    font-weight: 800;

    margin-right: 8px;
  }

  .services__bottom {
    margin-top: 30px;

    display: flex;

    justify-content: center;

    gap: 12px;

    flex-wrap: wrap;
  }

  @media (max-width: 980px) {

    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }

  }

  @media (max-width: 640px) {

    .services__grid {
      grid-template-columns: 1fr;
    }

    .services__card {
      min-height: auto;
    }

  }

</style>